# Path to the Caddyfile on the host system
CADDYFILE_PATH=/etc/caddy/Caddyfile

# Port the app listens on (default: 3000)
# Next.js reads this natively — no extra configuration needed.
# PORT=3000

# Restrict access to local/LAN IPs only (default: true)
# Set to false to allow connections from any IP
# LOCAL_ONLY=false

# Shared-secret token for authentication.
# If unset, auth is skipped (backwards compatible).
# Generate with: openssl rand -hex 32
# SECRET_TOKEN=

# Binary paths (optional overrides for non-standard distros or macOS)
# Defaults shown — only set these if your system uses different paths.
# CP_BIN=/bin/cp
# CADDY_BIN=/usr/bin/caddy
# SYSTEMCTL_BIN=/bin/systemctl
# JOURNALCTL_BIN=/usr/bin/journalctl
